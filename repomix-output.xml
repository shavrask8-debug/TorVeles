                            Icon(Icons.Default.ContentPaste, contentDescription = "Вставити з буфера", modifier = Modifier.size(20.dp))
                        }
                    },
                    modifier = Modifier.fillMaxWidth().clearFocusOnKeyboardDismiss(),
                    shape = MaterialTheme.shapes.medium,
                    maxLines = 3
